{
  "manifest_version": 3,
  "name": "Locali — השווה מחירים מקומיים",
  "version": "0.3.0",
  "description": "השווה מחירי מחו״ל עם חנויות מקומיות בישראל — עובד בכל אתר",
  "permissions": [
    "geolocation",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*",
    "http://localhost:8000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "exclude_matches": [
        "https://mail.google.com/*",
        "https://docs.google.com/*",
        "https://drive.google.com/*",
        "https://calendar.google.com/*",
        "https://accounts.google.com/*",
        "https://*.facebook.com/*",
        "https://*.twitter.com/*",
        "https://x.com/*",
        "https://*.youtube.com/*",
        "https://*.wikipedia.org/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "panel.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}